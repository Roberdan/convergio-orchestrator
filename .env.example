# ============================================
# convergio-orchestrator — Environment Variables
# ============================================

# --- Authentication (required) ---
# API token for orchestrator authentication
CONVERGIO_API_TOKEN=your-api-token-here

# Auth token for downstream service calls
CONVERGIO_AUTH_TOKEN=your-auth-token-here

# --- Infrastructure ---
# URL of the Convergio daemon (default: http://127.0.0.1:7777)
# CONVERGIO_DAEMON_URL=http://127.0.0.1:7777

# Directory for storing pipeline artifacts
# CONVERGIO_ARTIFACTS_DIR=/path/to/artifacts

# File gate mode (e.g., strict, permissive)
# CONVERGIO_FILE_GATE_MODE=strict

# --- Notifications (Telegram) ---
# Telegram bot token for sending notifications
# CONVERGIO_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID for receiving notifications
# CONVERGIO_TELEGRAM_CHAT_ID=your-chat-id-here
